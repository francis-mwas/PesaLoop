            "method": "POST",
            "url": "{{BASE_URL}}/webhooks/mpesa/c2b/confirmation",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TransactionType\": \"Pay Bill\",\n  \"TransID\": \"UNMATCHED999\",\n  \"TransAmount\": \"5000.00\",\n  \"BusinessShortCode\": \"522533\",\n  \"BillRefNumber\": \"WRONG-REF\",\n  \"MSISDN\": \"254700000000\",\n  \"FirstName\": \"Unknown\",\n  \"LastName\": \"Person\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// Safaricom always gets 200 — we handle unmatched internally",
                "pm.test('Status 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        },
        {
          "name": "Check unmatched payments queue",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/payments/unmatched",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }]
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has unmatched payment', () =>",
                "  pm.expect(pm.response.json().data.length).to.be.above(0));"
              ]
            }
          }]
        }
      ]
    },

    {
      "name": "08 — Validation Edge Cases",
      "item": [
        {
          "name": "Bad phone — invalid format",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"0712ABC456\",\n  \"fullName\": \"Test\",\n  \"password\": \"test1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400', () => pm.response.to.have.status(400));",
                "pm.test('Has INVALID_PHONE code', () =>",
                "  pm.expect(pm.response.json().code).to.equal('INVALID_PHONE'));"
              ]
            }
          }]
        },
        {
          "name": "Duplicate phone registration",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254712000001\",\n  \"fullName\": \"Alice Again\",\n  \"password\": \"test1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));",
                "pm.test('PHONE_EXISTS code', () =>",
                "  pm.expect(pm.response.json().code).to.equal('PHONE_EXISTS'));"
              ]
            }
          }]
        },
        {
          "name": "Overpayment rejected",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/contributions/manual",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberId\": \"33333333-0000-0000-0001-000000000001\",\n  \"cycleId\": \"55555555-0000-0000-0001-000000000004\",\n  \"amount\": 9999999,\n  \"paymentMethod\": \"CASH\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 or 409', () =>",
                "  pm.expect([400, 409]).to.include(pm.response.code));"
              ]
            }
          }]
        }
      ]
    }

  ]
}
