{
  "info": {
    "name": "PesaLoop API — Full Test Suite",
    "description": "Complete API test collection covering all scenarios. Import into Postman or use with Bruno (https://www.usebruno.com).\n\nSeed data password: test1234\nBase URL: http://localhost:8080",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "BASE_URL",     "value": "http://localhost:8080" },
    { "key": "TOKEN_ALICE",  "value": "" },
    { "key": "TOKEN_BRIAN",  "value": "" },
    { "key": "GROUP_ID_1",   "value": "22222222-0000-0000-0000-000000000001" },
    { "key": "GROUP_ID_SUSPENDED", "value": "22222222-0000-0000-0000-000000000004" }
  ],
  "item": [

    {
      "name": "01 — Authentication",
      "item": [
        {
          "name": "Register new user",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254700009999\",\n  \"fullName\": \"Test New User\",\n  \"password\": \"test1234\",\n  \"email\": \"newuser@test.co.ke\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Has userId', () => pm.expect(pm.response.json().data.userId).to.exist);"
              ]
            }
          }]
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/otp/send",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254700009999\",\n  \"purpose\": \"REGISTRATION\"\n}"
            }
          }
        },
        {
          "name": "Login — Alice (Group 1 admin)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254712000001\",\n  \"password\": \"test1234\",\n  \"groupId\": \"22222222-0000-0000-0000-000000000001\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('Has token', () => pm.expect(body.data.token).to.exist);",
                "pm.collectionVariables.set('TOKEN_ALICE', body.data.token);"
              ]
            }
          }]
        },
        {
          "name": "Login — multi-group (no groupId, expect group list)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254712000001\",\n  \"password\": \"test1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('Has available groups', () => pm.expect(body.data.availableGroups.length).to.be.above(0));",
                "pm.test('No token yet', () => pm.expect(body.data.token).to.be.null);"
              ]
            }
          }]
        },
        {
          "name": "Get my groups",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/auth/my-groups",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }]
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has groups', () => pm.expect(pm.response.json().data.length).to.be.above(0));"
              ]
            }
          }]
        }
      ]
    },

    {
      "name": "02 — Group & Member Management",
      "item": [
        {
          "name": "Create new group",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/groups",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kisumu Investment Club\",\n  \"groupType\": \"INVESTMENT\",\n  \"currencyCode\": \"KES\",\n  \"contributionFrequency\": \"MONTHLY\",\n  \"shareConfig\": {\n    \"pricePerShare\": 5000,\n    \"minimumShares\": 1,\n    \"maximumShares\": 10,\n    \"sharesMode\": true\n  }\n}"
            }
          }
        },
        {
          "name": "Add member — existing PesaLoop user",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/members",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254722000002\",\n  \"fullName\": \"Brian Mwangi Kahara\",\n  \"role\": \"MEMBER\",\n  \"sharesOwned\": 5\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201 or 409 if already member', () => pm.expect([201,409]).to.include(pm.response.code));",
                "if (pm.response.code === 201) {",
                "  pm.test('isNewUser false — phone already registered', () =>",
                "    pm.expect(pm.response.json().data.isNewUser).to.be.false);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Add member — new user (triggers invite SMS)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/v1/members",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"254700009888\",\n  \"fullName\": \"New Member Completely Fresh\",\n  \"role\": \"MEMBER\",\n  \"sharesOwned\": 3,\n  \"nextOfKinName\": \"Spouse Name\",\n  \"nextOfKinPhone\": \"254711111111\",\n  \"nextOfKinRelationship\": \"SPOUSE\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('isNewUser true', () =>",
                "  pm.expect(pm.response.json().data.isNewUser).to.be.true);",
                "pm.test('inviteSent true', () =>",
                "  pm.expect(pm.response.json().data.inviteSent).to.be.true);"
              ]
            }
          }]
        },
        {
          "name": "List all members",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/members",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN_ALICE}}" }]
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has members', () => pm.expect(pm.response.json().data.length).to.be.above(0));"
              ]
            }
          }]
        }
      ]
    },

