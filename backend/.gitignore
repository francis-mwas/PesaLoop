# Compiled files
*.class

# Logs
*.log
logs/

# Package artifacts
*.jar
*.war
*.ear

# JVM crash logs
hs_err_pid*
replay_pid*

# ==========================================================
# MAVEN
# ==========================================================

# Build directory
/target/

# Maven metadata
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Maven wrapper (optional — commit wrapper if team project)
.mvn/wrapper/maven-wrapper.jar

